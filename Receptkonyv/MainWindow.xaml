<Window x:Class="Receptkonyv.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Receptkonyv"
        mc:Ignorable="d"
       Title="Receptkönyv - Főmenü" Height="450" Width="800" WindowStartupLocation="CenterScreen">

	<DockPanel>

		<Menu DockPanel.Dock="Top" FontSize="14" Padding="5">
			<MenuItem Header="_Fájl">
				<MenuItem Header="_Kilépés" Click="Kilepes_Click"/>
			</MenuItem>
			<MenuItem Header="_Kezelés">
				<MenuItem Header="_Kategóriák kezelése" Click="Kategoriak_Click"/>
				<MenuItem Header="_Receptek kezelése" Click="Receptek_Click"/>
			</MenuItem>
		</Menu>

		<Grid Background="#FFF3E0">
			<TextBlock Text="Üdvözöllek a Receptkönyv alkalmazásban!"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#D84315"/>
		</Grid>
	</DockPanel>
</Window>
