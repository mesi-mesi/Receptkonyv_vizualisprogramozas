<Window x:Class="Receptkonyv.ReceptSzerkesztoAblak"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recept Szerkesztése" Height="250" Width="400" WindowStartupLocation="CenterOwner">

	<Grid x:Name="grFelulet" Margin="10">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="140"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="40"/>
			<RowDefinition Height="40"/>
			<RowDefinition Height="40"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Label Content="Recept címe:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0"/>
		<TextBox Text="{Binding Cim}" VerticalContentAlignment="Center" Margin="5" Grid.Row="0" Grid.Column="1"/>

		<Label Content="Elkészítési idő (perc):" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0"/>
		<TextBox Text="{Binding ElkeszitesiIdo}" VerticalContentAlignment="Center" Margin="5" Grid.Row="1" Grid.Column="1"/>

		<Label Content="Kategória:" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0"/>
		<ComboBox x:Name="cbKategoria" DisplayMemberPath="Megnevezes" SelectedValuePath="Id"
                  SelectedValue="{Binding KategoriaId}" Margin="5" Grid.Row="2" Grid.Column="1"/>

		<StackPanel Orientation="Horizontal" Grid.Row="3" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="0,15,0,0">
			<Button Content="Mentés" IsDefault="True" Width="100" Height="30" Margin="10,0" Background="#81C784" Click="Mentés_Click"/>
			<Button Content="Mégse" IsCancel="True" Width="100" Height="30" Margin="10,0" Background="#E57373"/>
		</StackPanel>
	</Grid>
</Window>